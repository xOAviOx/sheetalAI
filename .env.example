# ============================================================
# SheetalAI — environment configuration (copy to .env)
# ============================================================
# Nothing here is required to RUN the local app. The pipeline
# reads cached files; the API/web only read pre-computed results.

# ---- Google Earth Engine (Phase 1 data pipeline only) ----
# One-time setup: run `earthengine authenticate` (see README).
# If you use a service account instead of interactive auth:
# GEE_SERVICE_ACCOUNT=your-sa@project.iam.gserviceaccount.com
# GEE_PRIVATE_KEY_FILE=./.ee_credentials/key.json
GEE_PROJECT=

# ---- Active city (defaults to ahmedabad if unset) ----
CITY=ahmedabad

# ---- Data root (where cached COGs/parquet live) ----
DATA_ROOT=./data

# ---- API ----
API_HOST=127.0.0.1
API_PORT=8000
# Comma-separated origins allowed by CORS (frontend dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# ---- Optional advisory LLM (Phase 8, feature-flagged) ----
# App is fully functional with this OFF.
ENABLE_ADVISORY=false
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Optional PostGIS upgrade (NOT needed for local run) ----
# USE_POSTGIS=false
# POSTGIS_DSN=postgresql://sheetal:sheetal@localhost:5432/sheetal
